{
  "hosting": {
    "public": "lusion.co/lusion.co",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "**/*.orig"
    ],
    "headers": [
      {
        "source": "**/*.@(html)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      },
      {
        "source": "**/*.@(js|css)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=3600"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/about",
        "destination": "/about/index.html"
      },
      {
        "source": "/projects",
        "destination": "/projects/index.html"
      },
      {
        "source": "/projects/**",
        "destination": "/projects/index.html"
      }
    ],
    "cleanUrls": false,
    "trailingSlash": false
  }
}
